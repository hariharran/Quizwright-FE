# Base URL of the Quizwright API (Quizwright-BE).
#
# Leave blank for local development: vite.config.js proxies API paths to
# VITE_API_TARGET (default http://127.0.0.1:8123), so no CORS is involved.
#
# Set this on the hosting provider for production, with no trailing slash:
#   VITE_API_BASE=https://quizwright-api.onrender.com
#
# Remember to add this app's origin to CORS_ORIGINS on the backend.
VITE_API_BASE=

# Dev-only: where the Vite proxy forwards API calls.
# VITE_API_TARGET=http://127.0.0.1:8123
